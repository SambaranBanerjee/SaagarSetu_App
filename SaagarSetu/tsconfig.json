{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "jsx": "react-jsx",
    "allowJs": true,
    "noEmit": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
